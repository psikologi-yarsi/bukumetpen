   keywords = {Bridget C O'Brien,David A Cook,Ilene B Harris,MEDLINE,NCBI,NIH,NLM,National Center for Biotechnology Information,National Institutes of Health,National Library of Medicine,Non-U.S. Gov't,PubMed Abstract,Publishing / standards*,Qualitative Research*,Research Design / standards,Research Report / standards*,Research Support,doi:10.1097/ACM.0000000000000388,pmid:24979285},
   pages = {1245-1251},
